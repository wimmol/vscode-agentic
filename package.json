{
	"name": "vscode-agentic",
	"displayName": "VS Code Agentic",
	"description": "Multi-repo, multi-agent workspace manager for Claude Code",
	"version": "0.0.1",
	"engines": {
		"vscode": "^1.96.0"
	},
	"categories": [
		"Other"
	],
	"activationEvents": [],
	"main": "./dist/extension.js",
	"contributes": {
		"commands": [
			{
				"command": "vscode-agentic.rootGlobal",
				"title": "Show All Repos",
				"category": "Agentic",
				"icon": "$(root-folder)"
			},
			{
				"command": "vscode-agentic.rootRepo",
				"title": "Show Repo Root",
				"category": "Agentic",
				"icon": "$(root-folder)"
			},
			{
				"command": "vscode-agentic.addRepo",
				"title": "Add Repository",
				"category": "Agentic",
				"icon": "$(add)"
			},
			{
				"command": "vscode-agentic.createAgent",
				"title": "Create Agent",
				"category": "Agentic",
				"icon": "$(add)"
			},
			{
				"command": "vscode-agentic.deleteAgent",
				"title": "Delete Agent",
				"category": "Agentic",
				"icon": "$(trash)"
			},
			{
				"command": "vscode-agentic.focusAgent",
				"title": "Focus Agent",
				"category": "Agentic"
			},
			{
				"command": "vscode-agentic.stopAgent",
				"title": "Stop Agent",
				"category": "Agentic",
				"icon": "$(debug-stop)"
			},
			{
				"command": "vscode-agentic.removeRepo",
				"title": "Remove Repository",
				"category": "Agentic",
				"icon": "$(close)"
			}
		],
		"menus": {
			"view/title": [
				{
					"command": "vscode-agentic.rootGlobal",
					"group": "navigation@1",
					"when": "view == vscode-agentic.agents"
				},
				{
					"command": "vscode-agentic.addRepo",
					"group": "navigation@2",
					"when": "view == vscode-agentic.agents"
				}
			],
			"commandPalette": [
				{
					"command": "vscode-agentic.rootGlobal",
					"when": "false"
				},
				{
					"command": "vscode-agentic.rootRepo",
					"when": "false"
				},
				{
					"command": "vscode-agentic.addRepo",
					"when": "false"
				},
				{
					"command": "vscode-agentic.createAgent",
					"when": "false"
				},
				{
					"command": "vscode-agentic.deleteAgent",
					"when": "false"
				},
				{
					"command": "vscode-agentic.focusAgent",
					"when": "false"
				},
				{
					"command": "vscode-agentic.stopAgent",
					"when": "false"
				},
				{
					"command": "vscode-agentic.removeRepo",
					"when": "false"
				}
			]
		},
		"viewsContainers": {
			"activitybar": [
				{
					"id": "vscode-agentic",
					"title": "Agentic",
					"icon": "resources/icon.svg"
				}
			]
		},
		"views": {
			"vscode-agentic": [
				{
					"type": "webview",
					"id": "vscode-agentic.agents",
					"name": "Agents"
				}
			]
		}
	},
	"scripts": {
		"compile": "npm run check-types && node esbuild.js",
		"check-types": "tsc --noEmit",
		"watch": "npm-run-all -p watch:*",
		"watch:esbuild": "node esbuild.js --watch",
		"watch:tsc": "tsc --noEmit --watch --project tsconfig.json",
		"package": "npm run check-types && node esbuild.js --production",
		"vscode:prepublish": "npm run package",
		"test": "vitest run",
		"test:watch": "vitest",
		"test:integration": "vscode-test",
		"lint": "biome check .",
		"lint:fix": "biome check --write .",
		"format": "biome format --write ."
	},
	"repository": {
		"type": "git",
		"url": "git+https://github.com/wimmol/vscode-agentic.git"
	},
	"license": "ISC",
	"devDependencies": {
		"@biomejs/biome": "^2.4.5",
		"@types/node": "^20.19.35",
		"@types/vscode": "^1.96.0",
		"@vscode/test-cli": "^0.0.12",
		"@vscode/test-electron": "^2.5.2",
		"@vscode/vsce": "^3.7.1",
		"esbuild": "^0.27.3",
		"npm-run-all2": "^8.0.4",
		"typescript": "~5.8.0",
		"vitest": "^4.0.18"
	},
	"dependencies": {
		"@vscode/codicons": "^0.0.44"
	}
}
