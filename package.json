{
	"name": "vscode-agentic",
	"displayName": "VS Code Agentic",
	"description": "Multi-repo, multi-agent workspace manager for Claude Code",
	"version": "0.0.1",
	"engines": {
		"vscode": "^1.96.0"
	},
	"categories": [
		"Other"
	],
	"activationEvents": [],
	"main": "./dist/extension.js",
	"contributes": {
		"configuration": {
			"title": "VS Code Agentic",
			"properties": {
				"vscode-agentic.maxAgentsPerRepo": {
					"type": "integer",
					"default": 5,
					"minimum": 1,
					"maximum": 20,
					"scope": "resource",
					"description": "Maximum number of agents per repository."
				},
				"vscode-agentic.maxWorktreesPerRepo": {
					"type": "integer",
					"default": 5,
					"minimum": 1,
					"maximum": 20,
					"scope": "resource",
					"description": "Maximum number of worktrees per repository."
				},
				"vscode-agentic.maxConcurrentAgents": {
					"type": "integer",
					"default": 10,
					"minimum": 1,
					"maximum": 50,
					"scope": "resource",
					"description": "Maximum total agents across all repositories."
				}
			}
		},
		"commands": [
			{
				"command": "vscode-agentic.addRepo",
				"title": "Add Repository",
				"category": "Agentic",
				"icon": "$(file-directory)"
			},
			{
				"command": "vscode-agentic.createAgent",
				"title": "Create Agent",
				"category": "Agentic",
				"icon": "$(add)"
			},
			{
				"command": "vscode-agentic.deleteAgent",
				"title": "Delete Agent",
				"category": "Agentic"
			},
			{
				"command": "vscode-agentic.focusAgent",
				"title": "Focus Agent",
				"category": "Agentic"
			},
			{
				"command": "vscode-agentic.focusAgentFromTile",
				"title": "Focus Agent",
				"category": "Agentic"
			},
			{
				"command": "vscode-agentic.deleteAgentFromTile",
				"title": "Delete Agent",
				"category": "Agentic",
				"icon": "$(trash)"
			},
			{
				"command": "vscode-agentic.copyBranchName",
				"title": "Copy Branch Name",
				"category": "Agentic"
			},
			{
				"command": "vscode-agentic.createAgentInRepo",
				"title": "Create Agent in Repo",
				"category": "Agentic",
				"icon": "$(add)"
			},
			{
				"command": "vscode-agentic.suspendAgent",
				"title": "Suspend Agent",
				"category": "Agentic"
			},
			{
				"command": "vscode-agentic.suspendAllIdle",
				"title": "Suspend All Idle Agents",
				"category": "Agentic"
			},
			{
				"command": "vscode-agentic.suspendAgentFromTile",
				"title": "Suspend Agent",
				"category": "Agentic",
				"icon": "$(debug-pause)"
			},
			{
				"command": "vscode-agentic.restoreAgentFromTile",
				"title": "Restore Agent",
				"category": "Agentic",
				"icon": "$(debug-start)"
			},
			{
				"command": "vscode-agentic.reviewChanges",
				"title": "Review Changes",
				"category": "Agentic",
				"icon": "$(git-compare)"
			},
			{
				"command": "vscode-agentic.createPR",
				"title": "Create PR",
				"category": "Agentic",
				"icon": "$(git-pull-request)"
			}
		],
		"viewsContainers": {
			"activitybar": [
				{
					"id": "vscode-agentic",
					"title": "Agentic",
					"icon": "resources/icon.svg"
				}
			]
		},
		"views": {
			"vscode-agentic": [
				{
					"id": "vscode-agentic.agents",
					"name": "Agents"
				}
			]
		},
		"menus": {
			"view/title": [
				{
					"command": "vscode-agentic.createAgent",
					"when": "view == vscode-agentic.agents && vscode-agentic.claudeAvailable != false",
					"group": "navigation@1"
				},
				{
					"command": "vscode-agentic.addRepo",
					"when": "view == vscode-agentic.agents",
					"group": "navigation@2"
				}
			],
			"view/item/context": [
				{
					"command": "vscode-agentic.reviewChanges",
					"when": "view == vscode-agentic.agents && viewItem =~ /WithDiffs$/",
					"group": "inline"
				},
				{
					"command": "vscode-agentic.deleteAgentFromTile",
					"when": "view == vscode-agentic.agents && viewItem =~ /^agentItem/",
					"group": "inline"
				},
				{
					"command": "vscode-agentic.reviewChanges",
					"when": "view == vscode-agentic.agents && viewItem =~ /WithDiffs$/",
					"group": "navigation"
				},
				{
					"command": "vscode-agentic.createPR",
					"when": "view == vscode-agentic.agents && viewItem =~ /WithDiffs$/",
					"group": "navigation"
				},
				{
					"command": "vscode-agentic.suspendAgentFromTile",
					"when": "view == vscode-agentic.agents && viewItem =~ /^agentItem(WithDiffs)?$/",
					"group": "lifecycle"
				},
				{
					"command": "vscode-agentic.restoreAgentFromTile",
					"when": "view == vscode-agentic.agents && viewItem =~ /^agentItemSuspended/",
					"group": "lifecycle"
				},
				{
					"command": "vscode-agentic.deleteAgentFromTile",
					"when": "view == vscode-agentic.agents && viewItem =~ /^agentItem/",
					"group": "destructive"
				},
				{
					"command": "vscode-agentic.copyBranchName",
					"when": "view == vscode-agentic.agents && viewItem =~ /^agentItem/",
					"group": "other"
				},
				{
					"command": "vscode-agentic.createAgentInRepo",
					"when": "view == vscode-agentic.agents && viewItem == repoGroup && vscode-agentic.claudeAvailable != false",
					"group": "inline"
				}
			]
		},
		"viewsWelcome": [
			{
				"view": "vscode-agentic.agents",
				"contents": "No agents yet.\n[Create Agent](command:vscode-agentic.createAgent)"
			}
		]
	},
	"scripts": {
		"compile": "npm run check-types && node esbuild.js",
		"check-types": "tsc --noEmit",
		"watch": "npm-run-all -p watch:*",
		"watch:esbuild": "node esbuild.js --watch",
		"watch:tsc": "tsc --noEmit --watch --project tsconfig.json",
		"package": "npm run check-types && node esbuild.js --production",
		"vscode:prepublish": "npm run package",
		"test": "vitest run",
		"test:watch": "vitest",
		"test:integration": "vscode-test",
		"lint": "biome check .",
		"lint:fix": "biome check --write .",
		"format": "biome format --write ."
	},
	"repository": {
		"type": "git",
		"url": "git+https://github.com/wimmol/vscode-agentic.git"
	},
	"devDependencies": {
		"@biomejs/biome": "^2.4.5",
		"@types/node": "^22.19.13",
		"@types/vscode": "^1.96.0",
		"@vscode/test-cli": "^0.0.12",
		"@vscode/test-electron": "^2.5.2",
		"@vscode/vsce": "^3.7.1",
		"esbuild": "^0.27.3",
		"npm-run-all2": "^8.0.4",
		"typescript": "~5.8.0",
		"vitest": "^3.2.4"
	}
}
