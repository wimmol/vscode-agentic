{
  "name": "vscode-agentic",
  "displayName": "Agentic",
  "description": "Convenient sidebar to keep all your Claude Code agents in plain sight",
  "icon": "images/icon.png",
  "version": "0.7.0",
  "publisher": "wimmol",
  "engines": {
    "vscode": "^1.74.0"
  },
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/wimmol/vscode-agentic"
  },
  "categories": [
    "Machine Learning",
    "SCM Providers",
    "Chat",
    "Other"
  ],
  "keywords": [
    "ai",
    "ai-agents",
    "agents",
    "automation",
    "worktree",
    "workspace",
    "git",
    "multi-repo"
  ],
  "activationEvents": [
    "onView:vscode-agentic.agents"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "viewsContainers": {
      "activitybar": [
        {
          "id": "vscode-agentic",
          "title": "Agentic",
          "icon": "$(hubot)"
        }
      ]
    },
    "configuration": {
      "title": "Agentic",
      "properties": {
        "vscode-agentic.dangerouslyBypassPermissions": {
          "type": "boolean",
          "default": false,
          "description": "Run agents with --dangerously-skip-permissions flag (no confirmation prompts)."
        },
        "vscode-agentic.summariser.enabled": {
          "type": "boolean",
          "default": true,
          "description": "Summarise long prompts and agent output with a local model. Falls back to truncation when disabled or the model fails."
        },
        "vscode-agentic.summariser.thresholdChars": {
          "type": "number",
          "default": 320,
          "minimum": 80,
          "description": "Only summarise text longer than this many characters. Shorter text is shown as-is."
        },
        "vscode-agentic.summariser.stabilityMs": {
          "type": "number",
          "default": 2000,
          "minimum": 200,
          "description": "Milliseconds text must remain unchanged before a summary is computed. Prevents re-running the model during streaming output."
        }
      }
    },
    "views": {
      "vscode-agentic": [
        {
          "type": "webview",
          "id": "vscode-agentic.agents",
          "name": "Agents"
        },
        {
          "id": "vscode-agentic.explorer",
          "name": "Agentic Explorer"
        },
        {
          "type": "webview",
          "id": "vscode-agentic.sourceControl",
          "name": "Agentic Source Control"
        }
      ]
    },
    "commands": [
      {
        "command": "vscode-agentic.explorer.newFile",
        "title": "New File...",
        "icon": "$(new-file)",
        "category": "Agentic"
      },
      {
        "command": "vscode-agentic.explorer.newFolder",
        "title": "New Folder...",
        "icon": "$(new-folder)",
        "category": "Agentic"
      },
      {
        "command": "vscode-agentic.explorer.rename",
        "title": "Rename...",
        "category": "Agentic"
      },
      {
        "command": "vscode-agentic.explorer.delete",
        "title": "Delete",
        "icon": "$(trash)",
        "category": "Agentic"
      },
      {
        "command": "vscode-agentic.explorer.copy",
        "title": "Copy",
        "category": "Agentic"
      },
      {
        "command": "vscode-agentic.explorer.cut",
        "title": "Cut",
        "category": "Agentic"
      },
      {
        "command": "vscode-agentic.explorer.paste",
        "title": "Paste",
        "category": "Agentic"
      },
      {
        "command": "vscode-agentic.explorer.copyPath",
        "title": "Copy Path",
        "category": "Agentic"
      },
      {
        "command": "vscode-agentic.explorer.copyRelativePath",
        "title": "Copy Relative Path",
        "category": "Agentic"
      },
      {
        "command": "vscode-agentic.explorer.revealInOS",
        "title": "Reveal in File Manager",
        "category": "Agentic"
      },
      {
        "command": "vscode-agentic.explorer.sendToTerminal",
        "title": "Send to Claude",
        "icon": "$(terminal)",
        "category": "Agentic"
      },
      {
        "command": "vscode-agentic.manageTemplates",
        "title": "Manage Agent Templates",
        "icon": "$(symbol-color)",
        "category": "Agentic"
      },
      {
        "command": "vscode-agentic.explorer.refresh",
        "title": "Refresh",
        "icon": "$(refresh)",
        "category": "Agentic"
      }
    ],
    "menus": {
      "view/title": [
        {
          "command": "vscode-agentic.explorer.newFile",
          "when": "view == 'vscode-agentic.explorer'",
          "group": "navigation"
        },
        {
          "command": "vscode-agentic.explorer.newFolder",
          "when": "view == 'vscode-agentic.explorer'",
          "group": "navigation"
        },
        {
          "command": "vscode-agentic.explorer.paste",
          "when": "view == 'vscode-agentic.explorer'",
          "group": "1_paste"
        },
        {
          "command": "vscode-agentic.explorer.refresh",
          "when": "view == 'vscode-agentic.explorer'",
          "group": "navigation"
        }
      ],
      "view/item/context": [
        {
          "command": "vscode-agentic.explorer.newFile",
          "when": "view == 'vscode-agentic.explorer' && viewItem == 'scopeHeader'",
          "group": "1_new@1"
        },
        {
          "command": "vscode-agentic.explorer.newFolder",
          "when": "view == 'vscode-agentic.explorer' && viewItem == 'scopeHeader'",
          "group": "1_new@2"
        },
        {
          "command": "vscode-agentic.explorer.paste",
          "when": "view == 'vscode-agentic.explorer' && viewItem == 'scopeHeader'",
          "group": "5_cutcopypaste@3"
        },
        {
          "command": "vscode-agentic.explorer.newFile",
          "when": "view == 'vscode-agentic.explorer' && viewItem =~ /^explorer/",
          "group": "1_new@1"
        },
        {
          "command": "vscode-agentic.explorer.newFolder",
          "when": "view == 'vscode-agentic.explorer' && viewItem =~ /^explorer/",
          "group": "1_new@2"
        },
        {
          "command": "vscode-agentic.explorer.sendToTerminal",
          "when": "view == 'vscode-agentic.explorer' && viewItem =~ /^explorer/",
          "group": "3_agent@1"
        },
        {
          "command": "vscode-agentic.explorer.cut",
          "when": "view == 'vscode-agentic.explorer' && viewItem =~ /^explorer/",
          "group": "5_cutcopypaste@1"
        },
        {
          "command": "vscode-agentic.explorer.copy",
          "when": "view == 'vscode-agentic.explorer' && viewItem =~ /^explorer/",
          "group": "5_cutcopypaste@2"
        },
        {
          "command": "vscode-agentic.explorer.paste",
          "when": "view == 'vscode-agentic.explorer' && viewItem =~ /^explorer/",
          "group": "5_cutcopypaste@3"
        },
        {
          "command": "vscode-agentic.explorer.copyPath",
          "when": "view == 'vscode-agentic.explorer' && viewItem =~ /^explorer/",
          "group": "6_copypath@1"
        },
        {
          "command": "vscode-agentic.explorer.copyRelativePath",
          "when": "view == 'vscode-agentic.explorer' && viewItem =~ /^explorer/",
          "group": "6_copypath@2"
        },
        {
          "command": "vscode-agentic.explorer.revealInOS",
          "when": "view == 'vscode-agentic.explorer' && viewItem =~ /^explorer/",
          "group": "6_copypath@3"
        },
        {
          "command": "vscode-agentic.explorer.rename",
          "when": "view == 'vscode-agentic.explorer' && viewItem =~ /^explorer/",
          "group": "7_modification@1"
        },
        {
          "command": "vscode-agentic.explorer.delete",
          "when": "view == 'vscode-agentic.explorer' && viewItem =~ /^explorer/",
          "group": "7_modification@2"
        }
      ]
    },
    "keybindings": [
      {
        "command": "vscode-agentic.explorer.copy",
        "key": "ctrl+c",
        "mac": "cmd+c",
        "when": "focusedView == 'vscode-agentic.explorer' && listFocus && !inputFocus"
      },
      {
        "command": "vscode-agentic.explorer.cut",
        "key": "ctrl+x",
        "mac": "cmd+x",
        "when": "focusedView == 'vscode-agentic.explorer' && listFocus && !inputFocus"
      },
      {
        "command": "vscode-agentic.explorer.paste",
        "key": "ctrl+v",
        "mac": "cmd+v",
        "when": "focusedView == 'vscode-agentic.explorer' && listFocus && !inputFocus"
      },
      {
        "command": "vscode-agentic.explorer.delete",
        "key": "delete",
        "mac": "cmd+backspace",
        "when": "focusedView == 'vscode-agentic.explorer' && listFocus && !inputFocus"
      },
      {
        "command": "vscode-agentic.explorer.rename",
        "key": "f2",
        "when": "focusedView == 'vscode-agentic.explorer' && listFocus && !inputFocus"
      },
      {
        "command": "vscode-agentic.explorer.rename",
        "key": "enter",
        "when": "focusedView == 'vscode-agentic.explorer' && listFocus && !inputFocus"
      }
    ]
  },
  "scripts": {
    "vscode:prepublish": "npm run typecheck && npm run compile:prod",
    "typecheck": "tsc --noEmit -p tsconfig.json && tsc --noEmit -p tsconfig.webview.json",
    "compile:prod": "esbuild src/extension.ts --bundle --outfile=out/extension.js --external:vscode --external:@xenova/transformers --external:onnxruntime-web --external:onnxruntime-node --external:sharp --format=cjs --platform=node --minify --drop:console --tsconfig=tsconfig.json && esbuild src/ui/index.tsx --bundle --outfile=out/ui/index.js --format=esm --jsx=automatic --loader:.ttf=file --minify --drop:console --tsconfig=tsconfig.webview.json && esbuild src/ui/sourceControl/index.tsx --bundle --outfile=out/ui/sourceControl.js --format=esm --jsx=automatic --loader:.ttf=file --minify --drop:console --tsconfig=tsconfig.webview.json && esbuild src/ui/templateEditor/index.tsx --bundle --outfile=out/ui/templateEditor.js --format=esm --jsx=automatic --loader:.ttf=file --minify --drop:console --tsconfig=tsconfig.webview.json",
    "compile": "esbuild src/extension.ts --bundle --outfile=out/extension.js --external:vscode --external:@xenova/transformers --external:onnxruntime-web --external:onnxruntime-node --external:sharp --format=cjs --platform=node --sourcemap --tsconfig=tsconfig.json && esbuild src/ui/index.tsx --bundle --outfile=out/ui/index.js --format=esm --jsx=automatic --loader:.ttf=file --sourcemap --tsconfig=tsconfig.webview.json && esbuild src/ui/sourceControl/index.tsx --bundle --outfile=out/ui/sourceControl.js --format=esm --jsx=automatic --loader:.ttf=file --sourcemap --tsconfig=tsconfig.webview.json && esbuild src/ui/templateEditor/index.tsx --bundle --outfile=out/ui/templateEditor.js --format=esm --jsx=automatic --loader:.ttf=file --sourcemap --tsconfig=tsconfig.webview.json",
    "package": "npx vsce package",
    "watch": "npm run compile -- --watch",
    "lint": "eslint src/",
    "lint:fix": "eslint src/ --fix",
    "format": "prettier --write \"src/**/*.{ts,tsx,css}\"",
    "format:check": "prettier --check \"src/**/*.{ts,tsx,css}\""
  },
  "devDependencies": {
    "@types/node": "^25.6.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@types/vscode": "^1.74.0",
    "@vscode/codicons": "^0.0.44",
    "@vscode/vsce": "^3.0.0",
    "esbuild": "^0.27.3",
    "eslint": "^9.0.0",
    "eslint-config-prettier": "^10.0.0",
    "eslint-plugin-react": "^7.37.0",
    "eslint-plugin-react-hooks": "^5.0.0",
    "prettier": "^3.4.0",
    "typescript": "^5.7.0",
    "typescript-eslint": "^8.0.0"
  },
  "dependencies": {
    "@xenova/transformers": "^2.17.2",
    "react": "^19.0.0",
    "react-dom": "^19.0.0"
  }
}
