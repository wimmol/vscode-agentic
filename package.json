{
  "name": "vscode-agentic",
  "displayName": "Agentic",
  "description": "Work on multiple repositories using AI agents on own worktrees",
  "icon": "images/icon.png",
  "version": "0.3.0",
  "publisher": "wimmol",
  "engines": {
    "vscode": "^1.74.0"
  },
  "license": "FSL-1.1-MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/wimmol/vscode-agentic"
  },
  "categories": [
    "Machine Learning",
    "SCM Providers",
    "Chat",
    "Other"
  ],
  "keywords": [
    "ai",
    "ai-agents",
    "agents",
    "automation",
    "worktree",
    "workspace",
    "git",
    "multi-repo"
  ],
  "activationEvents": [
    "onView:vscode-agentic.agents"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "viewsContainers": {
      "activitybar": [
        {
          "id": "vscode-agentic",
          "title": "Agentic",
          "icon": "$(hubot)"
        }
      ]
    },
    "configuration": {
      "title": "Agentic",
      "properties": {
        "vscode-agentic.dangerouslyBypassPermissions": {
          "type": "boolean",
          "default": false,
          "description": "Run agents with --dangerously-skip-permissions flag (no confirmation prompts)."
        },
        "vscode-agentic.generateMdPrompt": {
          "type": "string",
          "default": "",
          "markdownDescription": "Additional instructions appended to the **Generate Documentation** agent prompt."
        },
        "vscode-agentic.refactorPrompt": {
          "type": "string",
          "default": "",
          "markdownDescription": "Additional instructions appended to the **Refactor** agent prompt."
        }
      }
    },
    "views": {
      "vscode-agentic": [
        {
          "type": "webview",
          "id": "vscode-agentic.agents",
          "name": "Agents"
        },
        {
          "id": "vscode-agentic.explorer",
          "name": "Agentic Explorer"
        }
      ]
    },
    "commands": [
      {
        "command": "vscode-agentic.explorer.newFile",
        "title": "New File...",
        "icon": "$(new-file)",
        "category": "Agentic"
      },
      {
        "command": "vscode-agentic.explorer.newFolder",
        "title": "New Folder...",
        "icon": "$(new-folder)",
        "category": "Agentic"
      },
      {
        "command": "vscode-agentic.explorer.rename",
        "title": "Rename...",
        "category": "Agentic"
      },
      {
        "command": "vscode-agentic.explorer.delete",
        "title": "Delete",
        "icon": "$(trash)",
        "category": "Agentic"
      },
      {
        "command": "vscode-agentic.explorer.copy",
        "title": "Copy",
        "category": "Agentic"
      },
      {
        "command": "vscode-agentic.explorer.cut",
        "title": "Cut",
        "category": "Agentic"
      },
      {
        "command": "vscode-agentic.explorer.paste",
        "title": "Paste",
        "category": "Agentic"
      },
      {
        "command": "vscode-agentic.explorer.copyPath",
        "title": "Copy Path",
        "category": "Agentic"
      },
      {
        "command": "vscode-agentic.explorer.copyRelativePath",
        "title": "Copy Relative Path",
        "category": "Agentic"
      },
      {
        "command": "vscode-agentic.explorer.revealInOS",
        "title": "Reveal in Finder",
        "category": "Agentic"
      },
      {
        "command": "vscode-agentic.explorer.sendToTerminal",
        "title": "Send to Claude",
        "icon": "$(terminal)",
        "category": "Agentic"
      },
      {
        "command": "vscode-agentic.explorer.generateDocs",
        "title": "Generate Documentation",
        "icon": "$(book)",
        "category": "Agentic"
      },
      {
        "command": "vscode-agentic.explorer.refactor",
        "title": "Refactor",
        "icon": "$(wand)",
        "category": "Agentic"
      }
    ],
    "menus": {
      "view/title": [
        {
          "command": "vscode-agentic.explorer.newFile",
          "when": "view == 'vscode-agentic.explorer'",
          "group": "navigation"
        },
        {
          "command": "vscode-agentic.explorer.newFolder",
          "when": "view == 'vscode-agentic.explorer'",
          "group": "navigation"
        }
      ],
      "view/item/context": [
        {
          "command": "vscode-agentic.explorer.newFile",
          "when": "view == 'vscode-agentic.explorer' && viewItem =~ /^explorer/",
          "group": "1_new@1"
        },
        {
          "command": "vscode-agentic.explorer.newFolder",
          "when": "view == 'vscode-agentic.explorer' && viewItem =~ /^explorer/",
          "group": "1_new@2"
        },
        {
          "command": "vscode-agentic.explorer.sendToTerminal",
          "when": "view == 'vscode-agentic.explorer' && viewItem =~ /^explorer/",
          "group": "3_agent@1"
        },
        {
          "command": "vscode-agentic.explorer.generateDocs",
          "when": "view == 'vscode-agentic.explorer' && viewItem =~ /^explorer/",
          "group": "3_agent@2"
        },
        {
          "command": "vscode-agentic.explorer.refactor",
          "when": "view == 'vscode-agentic.explorer' && viewItem =~ /^explorer/",
          "group": "3_agent@3"
        },
        {
          "command": "vscode-agentic.explorer.cut",
          "when": "view == 'vscode-agentic.explorer' && viewItem =~ /^explorer/",
          "group": "5_cutcopypaste@1"
        },
        {
          "command": "vscode-agentic.explorer.copy",
          "when": "view == 'vscode-agentic.explorer' && viewItem =~ /^explorer/",
          "group": "5_cutcopypaste@2"
        },
        {
          "command": "vscode-agentic.explorer.paste",
          "when": "view == 'vscode-agentic.explorer' && viewItem =~ /^explorer/",
          "group": "5_cutcopypaste@3"
        },
        {
          "command": "vscode-agentic.explorer.copyPath",
          "when": "view == 'vscode-agentic.explorer' && viewItem =~ /^explorer/",
          "group": "6_copypath@1"
        },
        {
          "command": "vscode-agentic.explorer.copyRelativePath",
          "when": "view == 'vscode-agentic.explorer' && viewItem =~ /^explorer/",
          "group": "6_copypath@2"
        },
        {
          "command": "vscode-agentic.explorer.revealInOS",
          "when": "view == 'vscode-agentic.explorer' && viewItem =~ /^explorer/",
          "group": "6_copypath@3"
        },
        {
          "command": "vscode-agentic.explorer.rename",
          "when": "view == 'vscode-agentic.explorer' && viewItem =~ /^explorer/",
          "group": "7_modification@1"
        },
        {
          "command": "vscode-agentic.explorer.delete",
          "when": "view == 'vscode-agentic.explorer' && viewItem =~ /^explorer/",
          "group": "7_modification@2"
        }
      ]
    },
    "keybindings": [
      {
        "command": "vscode-agentic.explorer.copy",
        "key": "ctrl+c",
        "mac": "cmd+c",
        "when": "focusedView == 'vscode-agentic.explorer' && listFocus && !inputFocus"
      },
      {
        "command": "vscode-agentic.explorer.cut",
        "key": "ctrl+x",
        "mac": "cmd+x",
        "when": "focusedView == 'vscode-agentic.explorer' && listFocus && !inputFocus"
      },
      {
        "command": "vscode-agentic.explorer.paste",
        "key": "ctrl+v",
        "mac": "cmd+v",
        "when": "focusedView == 'vscode-agentic.explorer' && listFocus && !inputFocus"
      },
      {
        "command": "vscode-agentic.explorer.delete",
        "key": "delete",
        "mac": "cmd+backspace",
        "when": "focusedView == 'vscode-agentic.explorer' && listFocus && !inputFocus"
      },
      {
        "command": "vscode-agentic.explorer.rename",
        "key": "f2",
        "when": "focusedView == 'vscode-agentic.explorer' && listFocus && !inputFocus"
      },
      {
        "command": "vscode-agentic.explorer.rename",
        "key": "enter",
        "when": "focusedView == 'vscode-agentic.explorer' && listFocus && !inputFocus"
      }
    ]
  },
  "scripts": {
    "vscode:prepublish": "npm run compile:prod",
    "compile:prod": "esbuild src/extension.ts --bundle --outfile=out/extension.js --external:vscode --format=cjs --platform=node --minify && esbuild src/ui/index.tsx --bundle --outfile=out/ui/index.js --format=esm --jsx=automatic --loader:.ttf=file --minify",
    "compile": "esbuild src/extension.ts --bundle --outfile=out/extension.js --external:vscode --format=cjs --platform=node --sourcemap && esbuild src/ui/index.tsx --bundle --outfile=out/ui/index.js --format=esm --jsx=automatic --loader:.ttf=file --sourcemap",
    "package": "npx vsce package",
    "watch": "npm run compile -- --watch",
    "lint": "eslint src/",
    "lint:fix": "eslint src/ --fix",
    "format": "prettier --write \"src/**/*.{ts,tsx,css}\"",
    "format:check": "prettier --check \"src/**/*.{ts,tsx,css}\""
  },
  "devDependencies": {
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@types/vscode": "^1.74.0",
    "@vscode/codicons": "^0.0.44",
    "esbuild": "^0.27.3",
    "eslint": "^9.0.0",
    "eslint-config-prettier": "^10.0.0",
    "eslint-plugin-react": "^7.37.0",
    "eslint-plugin-react-hooks": "^5.0.0",
    "prettier": "^3.4.0",
    "typescript": "^5.7.0",
    "@vscode/vsce": "^3.0.0",
    "typescript-eslint": "^8.0.0"
  },
  "dependencies": {
    "react": "^19.0.0",
    "react-dom": "^19.0.0"
  }
}
