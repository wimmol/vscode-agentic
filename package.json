{
  "name": "vscode-agentic",
  "displayName": "Agentic",
  "description": "Work on multiple repositories using AI agents on own worktrees",
  "icon": "images/icon.png",
  "version": "0.1.1",
  "publisher": "wimmol",
  "engines": {
    "vscode": "^1.74.0"
  },
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/wimmol/vscode-agentic"
  },
  "categories": [
    "Machine Learning",
    "SCM Providers",
    "Chat",
    "Other"
  ],
  "keywords": [
    "ai",
    "ai-agents",
    "agents",
    "automation",
    "worktree",
    "workspace",
    "git",
    "multi-repo"
  ],
  "activationEvents": [
    "onView:vscode-agentic.agents"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "viewsContainers": {
      "activitybar": [
        {
          "id": "vscode-agentic",
          "title": "Agentic",
          "icon": "$(hubot)"
        }
      ]
    },
    "configuration": {
      "title": "Agentic",
      "properties": {
        "vscode-agentic.dangerouslyBypassPermissions": {
          "type": "boolean",
          "default": false,
          "description": "Run agents with --dangerously-skip-permissions flag (no confirmation prompts)."
        }
      }
    },
    "views": {
      "vscode-agentic": [
        {
          "type": "webview",
          "id": "vscode-agentic.agents",
          "name": "Agents"
        },
        {
          "id": "vscode-agentic.explorer",
          "name": "Agentic Explorer"
        }
      ]
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run compile:prod",
    "compile:prod": "esbuild src/extension.ts --bundle --outfile=out/extension.js --external:vscode --external:pg-hstore --format=cjs --platform=node --minify && esbuild src/ui/index.tsx --bundle --outfile=out/ui/index.js --format=esm --jsx=automatic --loader:.ttf=file --minify",
    "compile": "esbuild src/extension.ts --bundle --outfile=out/extension.js --external:vscode --external:pg-hstore --format=cjs --platform=node --sourcemap && esbuild src/ui/index.tsx --bundle --outfile=out/ui/index.js --format=esm --jsx=automatic --loader:.ttf=file --sourcemap",
    "package": "npx vsce package",
    "watch": "npm run compile -- --watch",
    "lint": "eslint src/",
    "lint:fix": "eslint src/ --fix",
    "format": "prettier --write \"src/**/*.{ts,tsx,css}\"",
    "format:check": "prettier --check \"src/**/*.{ts,tsx,css}\""
  },
  "devDependencies": {
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@types/vscode": "^1.74.0",
    "@vscode/codicons": "^0.0.44",
    "esbuild": "^0.27.3",
    "eslint": "^9.0.0",
    "eslint-config-prettier": "^10.0.0",
    "eslint-plugin-react": "^7.37.0",
    "eslint-plugin-react-hooks": "^5.0.0",
    "prettier": "^3.4.0",
    "typescript": "^5.7.0",
    "@vscode/vsce": "^3.0.0",
    "typescript-eslint": "^8.0.0"
  },
  "dependencies": {
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "sequelize": "^6.37.8",
    "sqlite3": "^5.1.7"
  }
}
