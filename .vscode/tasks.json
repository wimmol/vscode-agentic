{
	"version": "2.0.0",
	"tasks": [
		{
			"label": "watch",
			"dependsOn": ["watch:esbuild", "watch:tsc"],
			"presentation": {
				"reveal": "never"
			},
			"group": {
				"kind": "build",
				"isDefault": true
			}
		},
		{
			"type": "npm",
			"script": "watch:esbuild",
			"label": "watch:esbuild",
			"isBackground": true,
			"problemMatcher": "$esbuild-watch",
			"presentation": {
				"reveal": "never"
			}
		},
		{
			"type": "npm",
			"script": "watch:tsc",
			"label": "watch:tsc",
			"isBackground": true,
			"problemMatcher": "$tsc-watch",
			"presentation": {
				"reveal": "never"
			}
		}
	]
}
